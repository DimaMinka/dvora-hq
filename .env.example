APP_NAME="Dvora HQ"
NODE_ENV="development"
PORT=8080

# Secrets (Taken from GCP Secret Manager in production)
TELEGRAM_BOT_TOKEN="your_telegram_bot_token_here"
JWT_SECRET="your_jwt_secret_here"
AI_API_KEY="your_ai_api_key_here"
TELEGRAM_ADMIN_USERNAMES="dimaminka,another_admin"
# CORS allowlist: comma-separated list of allowed frontend origins
ALLOWED_ORIGINS="http://localhost:5173,https://your-production-domain.com"

# GCP Infrastructure Configuration
GCP_PROJECT_ID="your_gcp_project_id_here"
GCP_REGION="europe-west1"
GCS_AVATAR_BUCKET="your_gcp_project_id_here-avatars"
CLOUDTASKS_QUEUE_NAME="avatar-generation"
CLOUDSQL_INSTANCE_NAME="dvora-db"

# Database Configuration (For Local Cloud SQL Proxy Tunnel)
DB_HOST="127.0.0.1"
DB_USER="root"
DB_PASSWORD=""
DB_NAME="dvora_db"


