APP_NAME="Dvora HQ"
NODE_ENV="development"
PORT=8080

# Secrets (Taken from GCP Secret Manager in production)
TELEGRAM_BOT_TOKEN="your_telegram_bot_token_here"
JWT_SECRET="your_jwt_secret_here"
AI_API_KEY="your_ai_api_key_here"

# GCP Infrastructure Configuration
GCP_PROJECT_ID="your_gcp_project_id_here"
GCP_REGION="europe-west1"
GCS_AVATAR_BUCKET="your_gcp_project_id_here-avatars"
CLOUDTASKS_QUEUE_NAME="avatar-generation"
CLOUDSQL_INSTANCE_NAME="dvora-db"

